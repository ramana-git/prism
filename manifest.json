{
  "manifest_version": 3,
  "name": "Prism",
  "version": "1.0.0",
  "description": "One app, every user. Per-tab session isolation for multi-user testing.",

  "permissions": [
    "cookies",
    "tabs",
    "storage",
    "scripting",
    "activeTab"
  ],

  "optional_host_permissions": [
    "*://*/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Prism — One app, every user"
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
